<% html_title t(:label_kpi_dashboard) %>

<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'kpi_dashboard', plugin: 'my_plugin' %>
<% end %>

<div class="kpi-dashboard">
  <div class="toolbar-container">
    <div class="toolbar">
      <div class="title-container">
        <h2><%= t(:label_kpi_dashboard) %></h2>
      </div>
      
      <ul class="toolbar-items">
        <li class="toolbar-item">
          <label for="time-period-select"><%= t(:label_time_period) %>:</label>
          <select id="time-period-select" class="form--select">
            <option value="7"><%= t(:label_last_7_days) %></option>
            <option value="30" selected><%= t(:label_last_30_days) %></option>
            <option value="90"><%= t(:label_last_90_days) %></option>
            <option value="365"><%= t(:label_last_year) %></option>
          </select>
        </li>
        <li class="toolbar-item">
          <button id="refresh-dashboard" class="button -highlight">
            <%= t(:button_refresh) %>
          </button>
        </li>
      </ul>
    </div>
  </div>
  
  <div class="kpi-dashboard-content">
    <div class="row">
      <!-- Summary Cards -->
      <div class="col-md-12">
        <div class="kpi-card-container">
          <div class="kpi-summary-card">
            <div class="kpi-card-value" id="total-tasks">--</div>
            <div class="kpi-card-label"><%= t(:label_total_tasks) %></div>
          </div>
          
          <div class="kpi-summary-card">
            <div class="kpi-card-value" id="completed-tasks">--</div>
            <div class="kpi-card-label"><%= t(:label_completed_tasks) %></div>
          </div>
          
          <div class="kpi-summary-card">
            <div class="kpi-card-value" id="completion-rate">--</div>
            <div class="kpi-card-label"><%= t(:label_completion_rate) %></div>
          </div>
          
          <div class="kpi-summary-card">
            <div class="kpi-card-value" id="avg-completion-time">--</div>
            <div class="kpi-card-label"><%= t(:label_avg_completion_time) %></div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="row">
      <!-- Task Completion Trend -->
      <div class="col-md-8">
        <div class="kpi-chart-container">
          <h3 class="kpi-chart-title"><%= t(:label_task_completion_trend) %></h3>
          <div class="kpi-chart" id="task-completion-chart"></div>
        </div>
      </div>
      
      <!-- Task Status Distribution -->
      <div class="col-md-4">
        <div class="kpi-chart-container">
          <h3 class="kpi-chart-title"><%= t(:label_task_status_distribution) %></h3>
          <div class="kpi-chart" id="task-status-chart"></div>
        </div>
      </div>
    </div>
    
    <div class="row">
      <!-- Team Performance -->
      <div class="col-md-6">
        <div class="kpi-chart-container">
          <h3 class="kpi-chart-title"><%= t(:label_team_performance) %></h3>
          <div class="kpi-chart" id="team-performance-chart"></div>
        </div>
      </div>
      
      <!-- Story Points Delivered -->
      <div class="col-md-6">
        <div class="kpi-chart-container">
          <h3 class="kpi-chart-title"><%= t(:label_story_points_delivered) %></h3>
          <div class="kpi-chart" id="story-points-chart"></div>
        </div>
      </div>
    </div>
    
    <div class="row">
      <!-- Recent Activity Table -->
      <div class="col-md-12">
        <div class="kpi-table-container">
          <h3 class="kpi-table-title"><%= t(:label_recent_activity) %></h3>
          <table class="generic-table" id="recent-activity-table">
            <thead>
              <tr>
                <th><%= t(:label_date) %></th>
                <th><%= t(:label_work_package) %></th>
                <th><%= t(:label_type) %></th>
                <th><%= t(:label_status) %></th>
                <th><%= t(:label_assignee) %></th>
                <th><%= t(:label_story_points) %></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td colspan="6" class="loading-indicator">
                  <%= t(:label_loading_data) %>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Initialize the KPI Dashboard
    initKpiDashboard();
    
    // Refresh when time period changes
    document.getElementById('time-period-select').addEventListener('change', function() {
      loadDashboardData();
    });
    
    // Refresh button handler
    document.getElementById('refresh-dashboard').addEventListener('click', function() {
      loadDashboardData();
    });
  });
  
  function initKpiDashboard() {
    // Load initial data
    loadDashboardData();
  }
  
  function loadDashboardData() {
    const timePeriod = document.getElementById('time-period-select').value;
    
    // Show loading states
    document.getElementById('total-tasks').textContent = '...';
    document.getElementById('completed-tasks').textContent = '...';
    document.getElementById('completion-rate').textContent = '...';
    document.getElementById('avg-completion-time').textContent = '...';
    
    // Fetch data from the server
    fetch('<%= kpi_dashboard_data_path %>' + '?days=' + timePeriod)
      .then(response => response.json())
      .then(data => {
        // Update summary cards
        document.getElementById('total-tasks').textContent = data.summary.total_tasks;
        document.getElementById('completed-tasks').textContent = data.summary.completed_tasks;
        document.getElementById('completion-rate').textContent = data.summary.completion_rate + '%';
        document.getElementById('avg-completion-time').textContent = data.summary.avg_completion_time + ' days';
        
        // Update charts
        updateCompletionTrendChart(data.completion_trend);
        updateTaskStatusChart(data.status_distribution);
        updateTeamPerformanceChart(data.team_performance);
        updateStoryPointsChart(data.story_points);
        
        // Update recent activity table
        updateRecentActivityTable(data.recent_activity);
      })
      .catch(error => {
        console.error('Error loading KPI data:', error);
      });
  }
  
  function updateCompletionTrendChart(data) {
    // Implementation would depend on your charting library
    console.log('Updating completion trend chart with:', data);
  }
  
  function updateTaskStatusChart(data) {
    // Implementation would depend on your charting library
    console.log('Updating task status chart with:', data);
  }
  
  function updateTeamPerformanceChart(data) {
    // Implementation would depend on your charting library
    console.log('Updating team performance chart with:', data);
  }
  
  function updateStoryPointsChart(data) {
    // Implementation would depend on your charting library
    console.log('Updating story points chart with:', data);
  }
  
  function updateRecentActivityTable(activities) {
    const tableBody = document.querySelector('#recent-activity-table tbody');
    
    // Clear existing rows
    tableBody.innerHTML = '';
    
    if (activities.length === 0) {
      const emptyRow = document.createElement('tr');
      emptyRow.innerHTML = `<td colspan="6" class="no-data"><%= t(:label_no_data) %></td>`;
      tableBody.appendChild(emptyRow);
      return;
    }
    
    // Add new rows
    activities.forEach(activity => {
      const row = document.createElement('tr');
      row.innerHTML = `
        <td>${formatDate(activity.date)}</td>
        <td><a href="/work_packages/${activity.id}">${activity.subject}</a></td>
        <td>${activity.type}</td>
        <td>${activity.status}</td>
        <td>${activity.assignee || '-'}</td>
        <td>${activity.story_points || '-'}</td>
      `;
      tableBody.appendChild(row);
    });
  }
  
  function formatDate(dateString) {
    const date = new Date(dateString);
    return date.toLocaleDateString();
  }
</script>
